<div class="step-content">
  <h2>Select Date</h2>
  <% if @available_dates.any? %>
    <div class="dates-grid">
      <% @available_dates.each do |date| %>
        <a href="/book/<%= @movie.id %>/time?date=<%= date %>" class="date-card">
          <div class="date-day"><%= date.strftime('%a') %></div>
          <div class="date-number"><%= date.day %></div>
          <div class="date-month"><%= date.strftime('%b') %></div>
        </a>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <h3>No upcoming dates available</h3>
      <p>Try a different theater.</p>
      <%= link_to "← Back to Theaters", "/book/#{@movie.id}/theater?city=#{session[:booking_city]}", class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
