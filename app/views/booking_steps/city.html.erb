<div class="booking-wizard">
  <div class="step-content">
    <h2>Select Your City</h2>
    <% if @cities.present? && @cities.any? %>
      <div class="cities-grid">
        <% @cities.each do |city| %>
          <% next unless city.present? && @movie.present? %>
          <a href="/book/<%= @movie.id %>/theater?city=<%= CGI.escape(city) %>" class="city-card">
            <div class="city-name"><%= city %></div>
            <div class="city-theaters"><%= @theater_counts[city] || 0 %> theater<%= (@theater_counts[city] || 0) == 1 ? '' : 's' %></div>
          </a>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <h3>No cities available for this movie</h3>
        <p>Showtimes haven't been scheduled yet. Check back soon.</p>
        <%= link_to "← Back to Movies", movies_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
