<div class="step-content">
  <h2>Select Showtime</h2>
  <% if @showtimes.present? && @showtimes.count > 0 %>
    <div class="showtimes-grid">
      <% @showtimes.each do |showtime| %>
        <a href="/movies/<%= @movie.id %>/bookings/new?showtime_id=<%= showtime.id %>" class="showtime-card">
          <div class="showtime-time"><%= showtime.start_time.strftime('%I:%M %p') %></div>
          <div class="showtime-screen">Screen <%= showtime.screen.name %></div>
          <div class="showtime-price">₹<%= showtime.price %></div>
          <div class="showtime-seats"><%= showtime.available_seats.count %> seats left</div>
        </a>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <h3>No showtimes available</h3>
      <p>Try a different date or theater.</p>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;justify-content:center;margin-top:1rem">
        <%= link_to "← Different Date", "/book/#{@movie.id}/date?theater_id=#{session[:booking_theater_id]}", class: "btn btn-secondary" %>
        <%= link_to "← Different Theater", "/book/#{@movie.id}/theater?city=#{session[:booking_city]}", class: "btn btn-secondary" %>
      </div>
    </div>
  <% end %>
</div>
