<div class="hero-section">
  <h1 class="hero-title">Now Showing in India</h1>
  <p class="hero-subtitle">Book tickets for the latest blockbusters in your city</p>
</div>

<div class="movies-section">
  <div class="section-header">
    <h2 class="section-title">Movies <span>in Theaters</span></h2>
  </div>

  <% if @movies.any? %>
    <div class="movies-grid">
      <% @movies.each do |movie| %>
        <div class="movie-card">
          <div class="movie-poster">
            <% if movie.poster_image_url.present? %>
              <img src="<%= movie.poster_image_url %>"
                   alt="<%= movie.title %>"
                   loading="lazy"
                   onerror="this.src='https://via.placeholder.com/300x450/12121a/606070?text=No+Poster'">
            <% else %>
              <img src="https://via.placeholder.com/300x450/12121a/606070?text=<%= ERB::Util.url_encode(movie.title) %>"
                   alt="<%= movie.title %>">
            <% end %>
            <div class="movie-poster-overlay">
              <%= link_to "Book Now", movie_path(movie), class: "btn btn-primary" %>
            </div>
          </div>
          <div class="movie-info">
            <h3 class="movie-title">
              <%= link_to movie.title, movie_path(movie) %>
            </h3>
            <div class="movie-badges">
              <% if movie.genre.present? %>
                <span class="badge badge-genre"><%= movie.genre.split('/').first %></span>
              <% end %>
              <% if movie.rating.present? %>
                <span class="badge badge-rating"><%= movie.rating %></span>
              <% end %>
              <% if movie.language.present? %>
                <span class="badge badge-lang"><%= movie.language %></span>
              <% end %>
            </div>
            <% if movie.duration.present? && movie.duration > 0 %>
              <p class="movie-duration"><%= movie.duration %> min</p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <h2>No movies available right now</h2>
      <p>Check back soon for upcoming releases.</p>
    </div>
  <% end %>
</div>
