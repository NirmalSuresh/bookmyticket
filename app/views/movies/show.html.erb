<% fallback_poster = asset_path('fallback-poster.svg') %>

<div class="movie-detail-page">
  <div class="breadcrumb">
    <%= link_to "Home", root_path %>
    <span class="breadcrumb-sep">›</span>
    <span><%= @movie.title %></span>
  </div>

  <div class="movie-detail-layout">
    <div class="movie-detail-poster">
      <%= image_tag(
            @movie.poster_image_url.presence || fallback_poster,
            alt: @movie.title,
            onerror: "this.onerror=null;this.src='#{fallback_poster}'"
          ) %>
    </div>

    <div class="movie-detail-info">
      <h1 class="movie-detail-title"><%= @movie.title %></h1>

      <div class="movie-meta-row">
        <% if @movie.genre.present? %>
          <span class="badge badge-genre"><%= @movie.genre %></span>
        <% end %>
        <% if @movie.rating.present? %>
          <span class="badge badge-rating"><%= @movie.rating %></span>
        <% end %>
        <% if @movie.language.present? %>
          <span class="badge badge-lang"><%= @movie.language %></span>
        <% end %>
      </div>

      <% if @movie.description.present? %>
        <p class="movie-description"><%= @movie.description %></p>
      <% end %>

      <div class="movie-detail-meta">
        <% if @movie.duration.present? && @movie.duration > 0 %>
          <div class="meta-item">
            <div class="meta-label">Duration</div>
            <div class="meta-value"><%= @movie.duration %> min</div>
          </div>
        <% end %>
        <% if @movie.director.present? %>
          <div class="meta-item">
            <div class="meta-label">Director</div>
            <div class="meta-value"><%= @movie.director %></div>
          </div>
        <% end %>
        <% if @movie.cast.present? %>
          <div class="meta-item">
            <div class="meta-label">Cast</div>
            <div class="meta-value"><%= @movie.cast %></div>
          </div>
        <% end %>
        <% if @movie.release_date.present? %>
          <div class="meta-item">
            <div class="meta-label">Release Date</div>
            <div class="meta-value"><%= @movie.release_date.strftime("%b %d, %Y") %></div>
          </div>
        <% end %>
      </div>

      <% if @movie.trailer_url.present? && @movie.youtube_embed_url.present? %>
        <div class="movie-trailer">
          <h3>Trailer</h3>
          <div class="trailer-embed">
            <iframe
              src="<%= @movie.youtube_embed_url %>"
              title="<%= @movie.title %> Trailer"
              allowfullscreen
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
            </iframe>
          </div>
        </div>
      <% end %>

      <div class="book-now-section">
        <%= link_to "Book Tickets", booking_steps_city_path(movie_id: @movie.id), class: "btn btn-primary btn-large" %>
        <%= link_to "← Back", root_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>
