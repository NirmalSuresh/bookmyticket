<% fallback_poster = asset_path('fallback-poster.svg') %>
<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
<% end %>

<div class="booking-detail-page">

  <% if @booking.confirmed? %>
    <%# ── CONFIRMED STATE ── %>
    <div style="text-align:center;padding:3rem 1rem">
      <div style="font-size:4rem;margin-bottom:1rem">🎉</div>
      <h1 style="font-size:2rem;font-weight:900;color:var(--text-primary);margin-bottom:0.5rem">Booking Confirmed!</h1>
      <p style="color:var(--text-muted);margin-bottom:2.5rem">Your tickets are locked in. See you at the movies!</p>
    </div>

    <div class="ticket-card" style="max-width:700px;margin:0 auto 2rem">
      <div class="ticket-header">
        <%= image_tag(
          @movie.poster_image_url.presence || fallback_poster,
          alt: @movie.title,
          class: "ticket-poster",
          onerror: "this.onerror=null;this.src='#{fallback_poster}'"
        ) %>
        <div class="ticket-movie-info">
          <h2><%= @movie.title %></h2>
          <span class="status-badge confirmed" style="margin-top:0.5rem;display:inline-block">✓ Confirmed</span>
        </div>
      </div>

      <div class="ticket-body">
        <div>
          <div class="ticket-field-label">Theater</div>
          <div class="ticket-field-value"><%= @theater.name %></div>
        </div>
        <div>
          <div class="ticket-field-label">Date</div>
          <div class="ticket-field-value"><%= @showtime.start_time.strftime("%d %b %Y") %></div>
        </div>
        <div>
          <div class="ticket-field-label">Time</div>
          <div class="ticket-field-value"><%= @showtime.start_time.strftime("%I:%M %p") %></div>
        </div>
        <div>
          <div class="ticket-field-label">Screen</div>
          <div class="ticket-field-value">Screen <%= @showtime.screen.name %></div>
        </div>
        <div>
          <div class="ticket-field-label">Seats</div>
          <div class="ticket-field-value" style="color:var(--accent);font-weight:800"><%= @booking.seats.join(', ') %></div>
        </div>
        <div>
          <div class="ticket-field-label">Tickets</div>
          <div class="ticket-field-value"><%= @booking.seats.count %></div>
        </div>
      </div>

      <div class="ticket-footer">
        <div class="booking-id">Booking ID <span>#<%= @booking.id %></span></div>
        <div class="total-amount">₹<%= @booking.total_price %></div>
      </div>
    </div>

    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
      <%= link_to "My Bookings", bookings_path, class: "btn btn-primary" %>
      <%= link_to "Browse More Movies", root_path, class: "btn btn-secondary" %>
    </div>

  <% else %>
    <%# ── PAYMENT STATE ── %>
    <div class="breadcrumb">
      <%= link_to "Movies", root_path %> <span class="breadcrumb-sep">›</span>
      <%= link_to @movie.title, movie_path(@movie) %> <span class="breadcrumb-sep">›</span>
      Payment
    </div>

    <h1 style="font-size:1.8rem;font-weight:900;margin-bottom:2rem">Complete Payment</h1>

    <div style="display:grid;grid-template-columns:1fr 360px;gap:2rem;align-items:start">

      <%# Left — Payment Method %>
      <div>
        <div class="step-content" style="margin-bottom:1.5rem">
          <h2>Order Summary</h2>

          <div style="display:flex;gap:1.25rem;align-items:flex-start;margin-bottom:1.5rem">
            <%= image_tag(
              @movie.poster_image_url.presence || fallback_poster,
              alt: @movie.title,
              style: "width:80px;height:120px;object-fit:cover;border-radius:8px;flex-shrink:0",
              onerror: "this.onerror=null;this.src='#{fallback_poster}'"
            ) %>
            <div>
              <div style="font-size:1.1rem;font-weight:800;margin-bottom:0.4rem"><%= @movie.title %></div>
              <div style="color:var(--text-muted);font-size:0.85rem;margin-bottom:0.25rem"><%= @theater.name %></div>
              <div style="color:var(--text-muted);font-size:0.85rem;margin-bottom:0.25rem">
                <%= @showtime.start_time.strftime("%d %b %Y · %I:%M %p") %> · Screen <%= @showtime.screen.name %>
              </div>
              <div style="color:var(--accent);font-weight:700;margin-top:0.5rem">
                Seats: <%= @booking.seats.join(', ') %>
              </div>
            </div>
          </div>

          <div style="border-top:1px solid var(--border);padding-top:1rem">
            <div class="summary-detail-row">
              <span class="label">Price per seat</span>
              <span class="value">₹<%= @showtime.price %></span>
            </div>
            <div class="summary-detail-row">
              <span class="label"><%= @booking.seats.count %> seat(s)</span>
              <span class="value">₹<%= @showtime.price * @booking.seats.count %></span>
            </div>
            <div class="summary-detail-row">
              <span class="label">Convenience fee (2%)</span>
              <span class="value">₹<%= ((@showtime.price * @booking.seats.count) * 0.02).round(2) %></span>
            </div>
            <hr class="summary-divider">
            <div class="summary-total">
              <span>Total</span>
              <span class="total-value">₹<%= @booking.total_price %></span>
            </div>
          </div>
        </div>

        <div class="step-content">
          <h2>Payment Method</h2>
          <div style="border:2px solid var(--accent);border-radius:var(--radius);padding:1.25rem;margin-bottom:1rem;background:var(--accent-glow)">
            <div style="display:flex;align-items:center;gap:0.75rem">
              <input type="radio" checked style="accent-color:var(--accent)">
              <div>
                <div style="font-weight:700;color:var(--text-primary)">🎭 Demo Payment</div>
                <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.2rem">Test mode — no real charges</div>
              </div>
            </div>
          </div>
          <div style="border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;opacity:0.5">
            <div style="display:flex;align-items:center;gap:0.75rem">
              <input type="radio" disabled>
              <div>
                <div style="font-weight:700;color:var(--text-primary)">💳 Razorpay — UPI / Card / Net Banking</div>
                <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.2rem">Coming soon</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# Right — Pay button sticky sidebar %>
      <div style="position:sticky;top:calc(var(--nav-height) + 1rem)">
        <div class="booking-summary-card">
          <h3>Pay Now</h3>
          <div style="font-size:2rem;font-weight:900;color:var(--accent);text-align:center;margin:1rem 0">
            ₹<%= @booking.total_price %>
          </div>
          <div style="font-size:0.8rem;color:var(--text-muted);text-align:center;margin-bottom:1.5rem">
            <%= @booking.seats.count %> ticket<%= @booking.seats.count > 1 ? 's' : '' %> · <%= @booking.seats.join(', ') %>
          </div>

          <%= form_with url: payment_success_movie_booking_path(@movie, @booking), method: :post, local: true, html: { id: "pay-form" } do |f| %>
            <button type="submit" class="btn btn-primary btn-large" style="width:100%" id="pay-btn">
              Pay ₹<%= @booking.total_price %>
            </button>
          <% end %>

          <div style="text-align:center;margin-top:1rem;font-size:0.75rem;color:var(--text-subtle)">
            🔒 Secure demo payment · No real charges
          </div>

          <hr class="summary-divider" style="margin:1.25rem 0">

          <%= button_to "Cancel Booking", cancel_booking_path(@booking),
                method: :patch,
                data: { turbo_confirm: "Cancel this booking? This cannot be undone." },
                class: "btn btn-secondary",
                style: "width:100%;margin-top:0" %>
        </div>
      </div>

    </div>
  <% end %>

</div>

<script>
var form = document.getElementById('pay-form');
var btn = document.getElementById('pay-btn');
if (form && btn) {
  form.addEventListener('submit', function() {
    btn.textContent = '⏳ Processing...';
    btn.disabled = true;
  });
}
</script>
